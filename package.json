{
  "name": "claudicus",
  "version": "1.0.0",
  "description": "A top-down 2D tile-based sprite RPG",
  "license": "MIT",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=dist/game.js --watch --sourcemap",
    "build": "esbuild src/main.ts --bundle --outfile=dist/game.js --minify",
    "build:vercel": "npm run build && mkdir -p public/dist && cp index.html style.css favicon.svg favicon.png public/ && cp dist/game.js public/dist/game.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
